{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "Equalizer - Web Audio EQ for YouTube, Spotify & Browser",
  "short_name": "Web Audio EQ",
  "version": "1.0.6",
  "description": "__MSG_extDescription__",
  "icons": {
    "128": "IconoEcualizador.png"
  },
  "action": {
    "default_popup": "popup/index.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabCapture",
    "offscreen",
    "identity",
    "tabs",
    "favicon",
    "scripting",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "<all_urls>",
    "https://*.firebaseio.com/*",
    "https://*.googleapis.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://smart-audio-eq.pages.dev/*",
      "http://localhost:5173/*"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
